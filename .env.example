# data-plane environment.
#
# Copy to .env and fill in the secrets. NEO4J_PASSWORD has no default and
# the stack will refuse to start without it.

# ---- Shared ---------------------------------------------------------------

# Name of the external network owned by the inference/ compose project.
# Override only if your inference stack uses a non-default project name.
INFERENCE_NET=inference-net

# ---- Neo4j (consumed by chorus) ------------------------------------------

NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme-set-a-real-password

# Memory tuning — adjust to host capacity. Rule of thumb: heap_max ≈ 25% of
# RAM, pagecache ≈ 50% of RAM, leaving headroom for the OS.
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=2G
NEO4J_PAGECACHE=1G

# Plugins. Leave empty in airgap — NEO4J_PLUGINS pulls from the public CDN
# on first boot. Mirror plugin jars into the neo4j-chorus-plugins volume
# out-of-band instead.
NEO4J_PLUGINS=

# ---- Qdrant (consumed by docint) -----------------------------------------

QDRANT_VERSION=v1.17.0
QDRANT_VERSION_CUDA=v1.17.0-gpu-nvidia

# ---- Dev-only (only consumed when compose.override.yaml is layered on) --------

NEO4J_BOLT_HOST_PORT=7687
NEO4J_HTTP_HOST_PORT=7474
QDRANT_HTTP_HOST_PORT=6333
QDRANT_GRPC_HOST_PORT=6334
